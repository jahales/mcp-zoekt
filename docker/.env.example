# ============================================================
# Zoekt MCP - Docker Compose Configuration (example)
#
# Copy to .env and edit values:
#   cp .env.example .env
#
# Docker Compose automatically reads .env in this directory.
# ============================================================

# Activate one or both profiles:
#   workingtree - Index a local directory
#   github      - Mirror GitHub organization repos
COMPOSE_PROFILES=workingtree

# ── Working Tree Mode ──
# Absolute host path to index (must be mountable by Docker)
WORKSPACE_ROOT=/absolute/path/to/your/project

# Seconds between re-index cycles
INDEX_INTERVAL=60

# ── GitHub Mirror Mode ──
# Preferred: comma-separated org list
# GITHUB_ORGS=my-company,my-oss-org

# Legacy single-org fallback (used only if GITHUB_ORGS is unset)
# GITHUB_ORG=my-company

# Seconds between sync cycles
# SYNC_INTERVAL=3600
